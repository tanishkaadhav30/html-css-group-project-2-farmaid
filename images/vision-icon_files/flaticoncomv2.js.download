BAndAmznKeys(slot) {\r\n    const keys = slot.getTargetingKeys();\r\n    keys.forEach(key => {\r\n      if (key.startsWith(\"hb_\") || key.startsWith(\"amzn\")) {\r\n        slot.clearTargeting(key);\r\n      }\r\n    });\r\n  }\r\n\r\n  \/\/ Intervalo de comprobaci\u00f3n\r\n  setInterval(() => {\r\n    const ssmCurrentTime = Date.now();\r\n\r\n    for (const ssmSlotId in window.ssmAdSlotTime) {\r\n      const ssmLastRendered = window.ssmAdSlotTime[ssmSlotId];\r\n      const ssmLastLineItem = window.ssmAdSlotLineItem[ssmSlotId]; \/\/ recuperamos el lineItemId\r\n      const ssmDiffSeconds = (ssmCurrentTime - ssmLastRendered) \/ 1000;\r\n\r\n      if (ssmDiffSeconds >= ssmIntervalSeconds) {\r\n        const ssmElement = document.getElementById(ssmSlotId);\r\n        if (ssmElement && ssmIsInViewport(ssmElement)) {\r\n          const ssmSlot = googletag.pubads().getSlots().find(\r\n            s => s.getSlotElementId() === ssmSlotId\r\n          );\r\n\r\n          \/\/ \u2705 SOLO refresca si el \u00faltimo lineItemId fue 7002356118\r\n          if (ssmSlot && ssmLastLineItem === 7050801247) {\r\n            if (ssmSlot.getAdUnitPath().indexOf(\"1x1\") === -1) {\r\n              googletag.cmd.push(() => {\r\n                let ssmLastRefreshDate = new Date(ssmLastRendered).toLocaleTimeString(); \r\n                let ssmNewRefreshDate = new Date(ssmCurrentTime).toLocaleTimeString(); \r\n\r\n                \/\/ \ud83d\udd04 Limpia las claves hb_* y amzn* antes de refrescar\r\n                ssmClearHBAndAmznKeys(ssmSlot);\r\n\r\n                ssmSlot.setTargeting(\"up_recovery\", \"true\");\r\n                googletag.pubads().refresh([ssmSlot]);\r\n                ssmSmartTag.log(\"[SSM BOOST]=>\", ssmSlotId, 'last Refresh', ssmLastRefreshDate, 'new refresh date', ssmNewRefreshDate, ' each ', ssmDiffSeconds, \"secs\");\r\n              });\r\n              window.ssmAdSlotTime[ssmSlotId] = ssmCurrentTime;\r\n            }\r\n          }\r\n        }\r\n      